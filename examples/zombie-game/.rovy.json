{
	"$schema": "../../packages/core/schema/rovy.schema.json",
	"current": "dev",
	"environments": {
		"dev": {
			"rojo": "default.project.json",
			"boundaries": {
				"server": ["src/server"],
				"client": ["src/client"],
				"shared": ["src/shared"]
			},
			"net": {
				"strictBoundaryChecks": true,
				"transport": "blink",
				"blink": {
					"enabled": true,
					"remoteScope": "ROVY",
					"manualReplication": true,
					"usePolling": true
				}
			}
		}
	}
}
