{
  "name": "rovy-core",
  "tree": {
    "$className": "DataModel",
    "ReplicatedStorage": {
      "rovy": {
        "$path": "out"
      },
      "rbxts_include": {
        "$path": "include",
        "node_modules": {
          "$className": "Folder",
          "@rbxts": {
            "$path": "node_modules/@rbxts"
          }
        }
      }
    }
  }
}
