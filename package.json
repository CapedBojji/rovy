{
  "name": "rovy",
  "private": true,
  "packageManager": "pnpm@11.1.2",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "build:core": "pnpm --filter @rovy/core build",
    "test:core": "pnpm --filter @rovy/core test",
    "build:transformer": "pnpm --filter rovy-transformer build",
    "test:transformer": "pnpm --filter rovy-transformer test"
  }
}
