{
	"name": "rovy-multiplace-arena-tests",
	"globIgnorePaths": ["**/package.json", "**/tsconfig.json"],
	"tree": {
		"$className": "DataModel",
		"ServerScriptService": {
			"$className": "ServerScriptService",
			"TS": {
				"$path": "../../out/arena/arena/src/server"
			}
		},
		"ReplicatedStorage": {
			"$className": "ReplicatedStorage",
			"rbxts_include": {
				"$path": "../../include",
				"node_modules": {
					"$className": "Folder",
					"@rbxts": {
						"$path": "../../node_modules/@rbxts"
					},
					"@rovy": {
						"$className": "Folder",
						"core": {
							"$path": "../../node_modules/@rovy/core"
						},
						"jecs": {
							"$path": "../../node_modules/@rovy/jecs"
						},
						"networking": {
							"$path": "../../node_modules/@rovy/networking"
						},
						"ui": {
							"$path": "../../node_modules/@rovy/ui"
						},
						"world-inspector": {
							"$className": "Folder",
							"out": {
								"$path": "../../node_modules/@rovy/world-inspector/out"
							},
							"node_modules": {
								"$className": "Folder",
								"@rovy": {
									"$className": "Folder",
									"core": {
										"$path": "../../node_modules/@rovy/world-inspector/node_modules/@rovy/core"
									},
									"jecs": {
										"$path": "../../node_modules/@rovy/jecs"
									},
									"networking": {
										"$path": "../../node_modules/@rovy/world-inspector/node_modules/@rovy/networking"
									},
									"ui": {
										"$path": "../../node_modules/@rovy/world-inspector/node_modules/@rovy/ui"
									}
								}
							}
						}
					}
				}
			},
			"Shared": {
				"$path": "../../out/arena/shared/src"
			},
			"RovyRobloxTests": {
				"$path": "test/roblox"
			}
		},
		"StarterPlayer": {
			"$className": "StarterPlayer",
			"StarterPlayerScripts": {
				"$className": "StarterPlayerScripts",
				"TS": {
					"$path": "../../out/arena/arena/src/client"
				}
			}
		},
		"Workspace": {
			"$className": "Workspace",
			"SpawnLocation": {
				"$className": "SpawnLocation",
				"$properties": {
					"Anchored": true,
					"Duration": 0,
					"Neutral": true,
					"Position": [0, 3, 0],
					"Size": [8, 1, 8]
				}
			}
		}
	}
}
