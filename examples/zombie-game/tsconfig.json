{
	"compilerOptions": {
		"allowSyntheticDefaultImports": true,
		"downlevelIteration": true,
		"jsx": "react",
		"jsxFactory": "React.createElement",
		"jsxFragmentFactory": "React.Fragment",
		"module": "commonjs",
		"moduleResolution": "Node",
		"noLib": true,
		"resolveJsonModule": true,
		"experimentalDecorators": true,
		"forceConsistentCasingInFileNames": true,
		"moduleDetection": "force",
		"skipLibCheck": true,
		"strict": true,
		"target": "ESNext",
		"typeRoots": ["node_modules/@rbxts", "node_modules/@rovy"],
		"rootDir": "src",
		"outDir": "out",
		"baseUrl": "src",
		"paths": {
			"@rovy/core": ["../node_modules/@rovy/core/out"],
			"@rovy/networking": ["../node_modules/@rovy/networking/out"],
			"@rovy/ui": ["../../packages/ui/out"],
			"@rovy/world-inspector": ["../node_modules/@rovy/world-inspector/out"]
		},
		"incremental": true,
		"tsBuildInfoFile": "out/tsconfig.tsbuildinfo",
		"plugins": [
			{
				"transform": "rovy-transformer",
				"config": ".rovy.json"
			}
		]
	},
	"include": ["src/**/*"],
	"exclude": ["node_modules", "out", "build", "test", "node_modules.symlink"]
}
