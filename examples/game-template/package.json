{
	"name": "@rovy/game-template",
	"private": true,
	"version": "1.0.0",
	"description": "Blank Rovy roblox-ts game template.",
	"main": "index.js",
	"scripts": {
		"compile": "node ../../packages/build/bin/rovy-build.js compile",
		"generate": "node ../../packages/build/bin/rovy-build.js generate",
		"build": "pnpm --filter rovy-transformer build && pnpm --filter rovy-build build && pnpm --filter @rovy/core build && node ../../packages/build/bin/rovy-build.js build",
		"watch": "node ../../packages/build/bin/rovy-build.js watch",
		"open": "node ../../packages/build/bin/rovy-build.js open",
		"start": "node ../../packages/build/bin/rovy-build.js start",
		"stop": "node ../../packages/build/bin/rovy-build.js stop",
		"check": "tsc -p tsconfig.json --noEmit --pretty false",
		"lint": "eslint \"src/**/*.ts\" && pnpm run check",
		"test:luau": "zune test test/smoke",
		"test:roblox": "pnpm run build && bash ../../scripts/run-roblox-test.sh tests.project.json ../../build/rovy-game-template-tests.rbxlx ../../test/roblox/run-tests.luau"
	},
	"keywords": [],
	"author": "",
	"license": "ISC",
	"devEngines": {
		"packageManager": {
			"name": "pnpm",
			"version": "^11.1.2",
			"onFail": "download"
		}
	},
	"type": "module",
	"dependencies": {
		"@rbxts/better-janitor": "^0.4.0",
		"@rovy/core": "workspace:*",
		"@rovy/jecs": "workspace:*"
	},
	"devDependencies": {
		"@rbxts/compiler-types": "3.0.0-types.0",
		"@rbxts/testez": "0.4.2-ts.0",
		"@rbxts/types": "^1.0.920",
		"@typescript-eslint/eslint-plugin": "^8.59.3",
		"@typescript-eslint/parser": "^8.59.3",
		"eslint": "^10.3.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-prettier": "^5.5.5",
		"eslint-plugin-roblox-ts": "^1.4.0",
		"prettier": "^3.8.3",
		"roblox-ts": "^3.0.0",
		"rovy-build": "workspace:*",
		"rovy-transformer": "workspace:*",
		"typescript": "5.5.3"
	},
	"rovy-build": {
		"$schema": "../../packages/core/schema/rovy-build.schema.json",
		"current": "dev",
		"placeFile": "../../build/rovy-game-template.rbxl",
		"rbxtscArgs": [
			"--type",
			"game"
		],
		"rojoBuildArgs": [
			"build",
			"default.project.json",
			"-o",
			"../../build/rovy-game-template.rbxl"
		],
		"watchOnOpen": true,
		"generateBlink": false,
		"environments": {
			"dev": {
				"rojo": "default.project.json",
				"sourcemap": "sourcemap.json",
				"boundaries": {
					"server": [
						"src/server"
					],
					"client": [
						"src/client"
					],
					"shared": [
						"src/shared"
					]
				}
			}
		}
	}
}
